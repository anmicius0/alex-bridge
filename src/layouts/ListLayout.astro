---
import Layout from './Layout.astro';
import Card from '../components/ui/Card.astro';

const {
  pageTitle = null,
  title = '',
  intro = '',
  description = null,
  ogImage = null,
  actions = null,
  maxWidth = 'max-w-3xl',
  isEmpty = false,
} = Astro.props;

const containerClass = `${maxWidth} mx-auto`;
---

<Layout
  title={pageTitle ?? title}
  description={description ?? intro ?? undefined}
  ogImage={ogImage ?? undefined}
>
  <section class="section">
    <div class={containerClass}>
      <div class="text-center mb-15">
        <h1 class="mb-4">{title}</h1>
        {intro && <p class="text-lg text-gray-600 md:text-xl">{intro}</p>}
      </div>

      {actions && <div class="flex justify-center mb-6">{actions}</div>}

      {
        isEmpty ? (
          <Card class="p-10 text-center">
            <h3 class="mb-2 text-xl font-bold">Keine Inhalte verfügbar</h3>
            <p>Schauen Sie bald wieder vorbei!</p>
          </Card>
        ) : (
          <div class="flex flex-col gap-6">
            <slot />
          </div>
        )
      }
    </div>
  </section>
</Layout>
