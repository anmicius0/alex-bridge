---
interface Props {
  class?: string;
}
import { Image } from 'astro:assets';
import grandmaImage from '../../../assets/grandma_playing_bridge_online.webp';
const { class: extraClass = '' } = Astro.props;
---

<section
  class={`py-12 md:py-20 flex flex-col md:flex-row items-center gap-10 md:gap-14 px-4 max-w-6xl mx-auto ${extraClass}`}
>
  <div class="flex flex-col items-start justify-center gap-5 md:w-1/2">
    <div
      class="inline-flex items-center gap-2 px-3 py-1.5 font-bold tracking-wide uppercase border-[3px] border-black rounded-full shadow-[3px_3px_0_#000] bg-[var(--color-accent)] text-[10px] md:text-xs"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-black animate-pulse"></span>
      Bridge Lernen Online & Vor Ort
    </div>

    <h1
      class="text-4xl font-black tracking-tight leading-[1.1] md:text-5xl lg:text-6xl"
    >
      Bridge spielen mit <span
        class="text-transparent bg-clip-text bg-gradient-to-br from-[var(--color-secondary)] to-[var(--color-accent)] [-webkit-text-stroke:1.5px_black]"
        >Leidenschaft.</span
      >
    </h1>

    <p
      class="text-base leading-relaxed text-gray-700 md:text-lg font-medium max-w-md"
    >
      Werden Sie Teil einer erstklassigen Bridge-Community in Lübeck. Von
      Anfängerkursen bis zu fortgeschrittenen Strategien.
    </p>
  </div>

  <div class="flex items-center justify-center p-4 md:w-1/2">
    <div class="relative group w-full max-w-sm">
      <div
        class="relative border-[3px] border-black rounded-2xl aspect-square shadow-[10px_10px_0_#000] overflow-hidden bg-[var(--color-accent)]"
      >
        <Image
          src={grandmaImage}
          alt="Bridge"
          class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-110"
          width={600}
          height={600}
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .floating-suit {
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }
</style>
