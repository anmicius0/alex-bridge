---
import type { CalendarEvent } from '../../types/content';
import { fetchCalendarEvents } from '@features/calendar/services/calendar';
import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/layout/PageHeader.astro';
import CalendarWrapper from '@features/calendar/components/CalendarWrapper.astro';
import { ErrorHandler } from '@lib/error-handler';

let events: CalendarEvent[] = [];

try {
  const result = await ErrorHandler.safeExecute(fetchCalendarEvents, {
    context: 'calendar/page/initial-fetch',
  });
  events = result.success ? (result.data ?? []) : [];
} catch (error) {
  ErrorHandler.logError(error, 'calendar/page/initial-fetch');
  events = [];
}

const title = 'Online-Kurse';
const description =
  'Durchsuchen Sie den Zeitplan für bevorstehende Bridge-Kurse. Alle Sitzungen finden live statt und sind interaktiv.';
---

<Layout title={title} description={description} width="wide">
  <PageHeader title={title} description={description} />
  <div class="mt-8">
    <CalendarWrapper events={events} />
  </div>
</Layout>
