---
import { Image } from 'astro:assets';
import { type CollectionEntry } from 'astro:content';
import squareImage from '@assets/alex/square.webp';
import { Button, Card, SectionHeader } from '@components';
import { getHolidayGroups } from '@features/holiday';
import { Hero } from '@features/home';
import { NewsBanner, getSortedNewsPosts } from '@features/news';
import Layout from '@layouts/Layout.astro';
import { logError } from '@lib/error-handler';

let newsPosts: CollectionEntry<'news'>[] = [];
let upcomingHolidays: CollectionEntry<'holiday'>[] = [];

try {
  newsPosts = await getSortedNewsPosts();
  const groups = await getHolidayGroups();
  upcomingHolidays = groups.upcoming.slice(0, 1);
} catch (error) {
  logError(error, { context: 'Homepage Collections Loading' });
}

const latestPost = newsPosts[0];
const recentPosts = newsPosts.slice(0, 2);
---

<Layout title="Bridge mit Alexander">
  <NewsBanner
    title={latestPost?.data.title}
    link={latestPost ? `/news/${latestPost.id}` : undefined}
  />
  <Hero />

  <section id="why" class="section">
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        title="Warum Bridge mit uns lernen?"
        description="Entdecken Sie die Vorteile unserer Bridge-Kurse"
      />
      <div class="grid gap-6 md:grid-cols-3">
        <Card
          icon="🎓"
          title="Expertenunterricht"
          description="Lernen Sie von erfahrenen Bridge-Profis mit jahrzehntelanger Erfahrung."
        />

        <Card
          icon="👥"
          title="Kleine Gruppen"
          description="Personalisierte Aufmerksamkeit in intimen Klasseneinstellungen."
        />

        <Card
          icon="📅"
          title="Flexible Zeitplanung"
          description="Wählen Sie aus einer Vielzahl von Kurszeiten."
        />
      </div>
    </div>
  </section>

  <section id="about" class="section">
    <div class="max-w-4xl mx-auto">
      <div class="p-8 card md:p-12">
        <div
          class="flex flex-col items-center gap-8 lg:flex-row lg:items-start lg:gap-12"
        >
          <div class="flex-shrink-0">
            <Image
              src={squareImage}
              alt="Alexander - Bridge-Lehrer"
              class="object-cover w-48 h-48 border-[3px] border-black rounded-2xl shadow-[4px_4px_0_#000] md:h-64 md:w-64"
              width={512}
              height={512}
            />
          </div>
          <div class="flex-1 space-y-4 text-center lg:text-left">
            <h2 class="text-3xl font-black leading-tight md:text-4xl">
              Alexander
            </h2>
            <p class="text-lg font-bold text-gray-700">
              Mehrfacher Deutscher Meister, Coach, Bridgelehrer, Turnierleiter
              und Reiseveranstalter
            </p>
            <p class="text-base text-gray-700">
              Alexander zählt zu den profiliertesten Persönlichkeiten der
              deutschen Bridgeszene. Das Bridgespielen hat er bereits im Alter
              von fünf Jahren von seinem Vater erlernt. Mit neun Jahren nahm er
              an seinem ersten Bridgeturnier teil – der Beginn einer
              außergewöhnlichen Karriere.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 space-y-6">
        <h3 class="text-2xl font-bold text-center">Berufliche Schwerpunkte</h3>
        <div class="grid gap-6 md:grid-cols-2">
          <Card icon="💼" title="Professioneller Lehrer" iconPosition="left">
            <ul class="space-y-2 text-gray-700">
              <li>• Bridgeunterricht für alle Spielstufen</li>
              <li>• Einführungskurse, Schulungsreihen</li>
              <li>• Turniertraining nach DBV-Standards</li>
            </ul>
          </Card>

          <Card icon="🏆" title="Coaching & Organisation" iconPosition="left">
            <ul class="space-y-2 text-gray-700">
              <li>• Coaching für ambitionierte Spieler und Clubs</li>
              <li>• Organisation von Bridge-Reisen und Seminaren</li>
              <li>• Entwicklung von Lehrmaterialien</li>
            </ul>
          </Card>
        </div>
      </div>

      <div class="p-8 mt-12 card">
        <h3 class="mb-6 text-2xl font-bold text-center">
          Erfolge & Auszeichnungen
        </h3>
        <div class="space-y-4 text-gray-700">
          <p>
            <strong>Im Alter von 17 Jahren</strong> wurde er erstmals in die deutsche
            Juniorennationalmannschaft berufen. Das Bridgespielen hat er zum Beruf
            gemacht und hat seitdem Hunderte von Schülern unterrichtet.
          </p>
          <ul class="space-y-2">
            <li>• <strong>Mehrfacher Deutscher Meister</strong></li>
            <li>• <strong>Erfolge</strong> bei internationalen Wettbewerben</li>
            <li>• <strong>Veranstalter</strong> renommierter Bridge-Events</li>
            <li>• <strong>Mentoring</strong> für Nachwuchsspieler</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {
    upcomingHolidays.length > 0 && (
      <section id="reisen" class="section">
        <div class="max-w-4xl mx-auto">
          <SectionHeader
            title="Kommende Reisen"
            description="Entdecken Sie unsere nächsten Bridge-Reisen"
          />
          <div class="grid gap-6 md:grid-cols-1">
            {upcomingHolidays.map((holiday) => (
              <Card
                title={holiday.data.title}
                images={holiday.data.images}
                href={`/holiday/${holiday.id}`}
                dateRange={{
                  start: holiday.data.startDate,
                  end: holiday.data.endDate,
                }}
                imagePosition="top"
              />
            ))}
          </div>
          <div class="flex justify-center mt-8">
            <Button text="Alle Reisen" href="/holiday" />
          </div>
        </div>
      </section>
    )
  }

  {
    recentPosts.length > 0 && (
      <section id="news" class="section">
        <div class="max-w-4xl mx-auto">
          <SectionHeader
            title="Neueste Beiträge"
            description="Aktuelle Bridge-Neuigkeiten und Tipps"
          />
          <div class="flex flex-col gap-6 md:flex-row">
            {recentPosts.map((post, index) => (
              <div class={index === 0 ? 'md:w-2/3 flex' : 'md:w-1/3 flex'}>
                <Card
                  title={post.data.title}
                  href={`/news/${post.id}`}
                  date={post.data.date}
                  images={post.data.images}
                  imagePosition="left"
                  class="w-full"
                />
              </div>
            ))}
          </div>
          <div class="flex justify-center mt-8">
            <Button text="Alle Beiträge" href="/news" />
          </div>
        </div>
      </section>
    )
  }
</Layout>
