---
import Button from '../ui/Button.astro';

const year = new Date().getFullYear();
const emailHref = 'mailto:alexis-bridge@gmx.de';
const whatsappHref = 'https://wa.me/+491794880345';

const { class: extraClass = '' } = Astro.props;
---

<footer class={`bg-white border-t border-gray-200 px-5 py-12 md:px-0 mt-12 ${extraClass}`}>
  <div class="max-w-6xl mx-auto flex flex-col items-center justify-between gap-8 md:flex-row md:px-8">
    <div class="flex items-center text-slate-900 font-display font-black">
      <span class="text-2xl tracking-tight">Bridge mit Alexander</span>
    </div>

    <p class="text-center text-sm text-slate-500 font-medium">
      © {year} Bridge Club. Alle Rechte vorbehalten.
    </p>

    <div class="flex items-center justify-center gap-4">
      <Button text="E-Mail" href={emailHref} variant="outline" size="sm" />
      <Button text="WhatsApp" href={whatsappHref} variant="outline" size="sm" />
    </div>
  </div>
</footer>