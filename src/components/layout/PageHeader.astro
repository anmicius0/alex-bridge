---
interface Props {
  title: string;
  description?: string;
  centered?: boolean;
}
const { title, description, centered = true } = Astro.props;
---

<div class:list={['mb-12 md:mb-16', centered && 'text-center']}>
  <h1 class="mb-4 text-slate-900">{title}</h1>
  {description && (
    <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
      {description}
    </p>
  )}
  <div class:list={['h-1.5 w-20 bg-secondary rounded-full mt-6', centered && 'mx-auto']}></div>
</div>