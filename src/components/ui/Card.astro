---
import { Image } from 'astro:assets';
import DateDisplay from '../content/DateDisplay.astro';

interface Props {
  title?: string;
  href?: string;
  date?: Date | string;
  dateRange?: { start: Date | string; end: Date | string };
  description?: string;
  images?: string[];
  imagePosition?: 'top' | 'left';
  class?: string;
}

const {
  title,
  href,
  date,
  dateRange,
  description,
  images = [],
  imagePosition = 'top',
  class: extraClass = '',
} = Astro.props;

const displayImage = images[0];
const isHorizontalImage = displayImage !== undefined && imagePosition === 'left';

const Tag = href ? 'a' : 'div';
---

<Tag 
  href={href} 
  class:list={[
    "group relative block p-1.5 rounded-[2rem] bg-black/[0.02] border border-black/[0.04] shadow-sm hover:shadow-md transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:-translate-y-0.5",
    extraClass
  ]}
>
  <div class:list={[
    "h-full w-full bg-white rounded-[calc(2rem-0.375rem)] overflow-hidden flex flex-col",
    isHorizontalImage ? "md:flex-row" : "flex-col"
  ]}>
    {
      displayImage && (
        <div class:list={[
          "overflow-hidden shrink-0 relative bg-accent/10",
          isHorizontalImage
            ? "w-full md:w-5/12 min-h-[260px] border-b border-black/[0.03] md:border-b-0 md:border-r border-dashed"
            : "w-full aspect-[16/10] border-b border-black/[0.03]"
        ]}>
          <Image
            src={displayImage}
            alt={title || 'Card image'}
            class="absolute inset-0 object-cover w-full h-full transition-transform duration-1000 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-[1.03]"
            width={800}
            height={600}
          />
        </div>
      )
    }

    <div class="p-6 md:p-8 flex flex-col flex-1 justify-between min-w-0">
      <div>
        <slot name="icon" />
        
        {
          (date || dateRange) && (
            <p class="mb-3 text-[10px] font-bold tracking-[0.15em] text-accent uppercase font-sans">
              {date && <DateDisplay date={date} />}
              {dateRange && (
                <>
                  <DateDisplay date={dateRange.start} /> -{' '}
                  <DateDisplay date={dateRange.end} />
                </>
              )}
            </p>
          )
        }

        {
          title && (
            <h3 class:list={[
              "mb-3 font-bold tracking-tight leading-[1.25] text-slate-900 text-balance font-display",
              isHorizontalImage ? "text-xl md:text-2xl" : "text-lg md:text-xl"
            ]}>
              {title}
            </h3>
          )
        }

        {
          description && (
            <p class="text-[15px] leading-relaxed text-slate-500 break-words line-clamp-3 font-sans">
              {description}
            </p>
          )
        }

        <div class="mt-4 font-sans">
          <slot />
        </div>
      </div>

      <slot name="footer" />
    </div>
  </div>
</Tag>