---
import { Image } from 'astro:assets';
import DateDisplay from '../content/DateDisplay.astro';

interface Props {
  title?: string;
  href?: string;
  date?: Date | string;
  dateRange?: { start: Date | string; end: Date | string };
  description?: string;
  images?: string[];
  imagePosition?: 'top' | 'left';
  icon?: string;
  iconPosition?: 'top' | 'left';
  contentLayout?: 'default' | 'centered';
  class?: string;
}

const {
  title,
  href,
  date,
  dateRange,
  description,
  images = [],
  imagePosition = 'top',
  icon,
  iconPosition = 'left',
  contentLayout = 'default',
  class: extraClass,
} = Astro.props;

const displayImage = images.length > 0 ? images[0] : undefined;
const hasImage = !!displayImage;
const isHorizontalImage = hasImage && imagePosition === 'left';
const hasIcon = !!icon;
const hasIconAtTop = hasIcon && iconPosition === 'top';
const hasIconAtLeft = hasIcon && iconPosition === 'left';

// Determine container classes based on props
const containerClasses = [
  'relative bg-[var(--color-primary)] border-[3px] border-black rounded-2xl transition-all duration-200',
  // Padding based on layout - increased for more spacious feel
  contentLayout === 'centered' ? 'p-8' : 'p-6',
  // Hover effects for non-link cards
  !href
    ? 'shadow-[3px_3px_0_#000]'
    : 'cursor-pointer shadow-[3px_3px_0_#000] hover:shadow-[6px_6px_0_#000] hover:-translate-x-[3px] hover:-translate-y-[3px] active:shadow-none active:translate-x-[3px] active:translate-y-[3px]',
  // Layout-specific classes: image on top on mobile, left on sm+
  isHorizontalImage
    ? 'flex flex-col sm:flex-row items-start sm:items-center gap-6'
    : contentLayout === 'centered'
      ? 'flex flex-col items-center text-center'
      : 'block',
  // Extra padding for top icon to prevent overlap
  hasIconAtTop && !isHorizontalImage ? 'pt-12' : '',
]
  .filter(Boolean)
  .join(' ');

const Tag = href ? 'a' : 'div';
---

<Tag href={href} class={`${containerClasses} ${extraClass}`}>
  {
    // Icon positioned at top (centered)
    hasIconAtTop && (
      <div class="absolute top-0 z-10 text-3xl -translate-x-1/2 -translate-y-1/2 left-1/2">
        {icon}
      </div>
    )
  }

  {
    // Icon positioned at left with inline title
    hasIconAtLeft && (
      <div class="flex items-center gap-3 mb-3">
        <span class="text-3xl">{icon}</span>
        {title && <h4 class="text-xl font-bold">{title}</h4>}
      </div>
    )
  }

  {
    // Image - rendered before content for horizontal layout
    // On mobile: full width on top, on sm+: side by side
    displayImage && (
      <div
        class={
          isHorizontalImage
            ? 'w-full overflow-hidden rounded-xl border-[3px] border-black mb-3 sm:mb-0 sm:flex-shrink-0 sm:w-28 sm:h-28 md:w-40 md:h-40'
            : hasIconAtTop
              ? 'w-full overflow-hidden rounded-xl border-[3px] border-black mt-4 mb-3'
              : 'w-full overflow-hidden rounded-xl border-[3px] border-black mb-3'
        }
      >
        <Image
          src={displayImage}
          alt={title || 'Card image'}
          class="object-cover w-full h-full"
          width={600}
          height={400}
        />
      </div>
    )
  }

  {
    // Content wrapper for horizontal image layout
    isHorizontalImage && (
      <div class="flex flex-col flex-1 min-w-0">
        {title && (
          <h3 class="mb-1 text-xl font-black leading-tight tracking-tight">
            {title}
          </h3>
        )}

        {(date || dateRange) && (
          <p class="mb-2 text-xs font-bold tracking-wide text-gray-600 uppercase">
            {date && <DateDisplay date={date} />}
            {dateRange && (
              <>
                <DateDisplay date={dateRange.start} /> -{' '}
                <DateDisplay date={dateRange.end} />
              </>
            )}
          </p>
        )}

        {description && (
          <p class="text-sm leading-relaxed text-gray-700 break-words">
            {description}
          </p>
        )}

        <slot />
      </div>
    )
  }

  {
    // Standard content flow (non-horizontal image)
    !isHorizontalImage && (
      <>
        {
          // Title: render only if not using icon-at-left (title already shown with icon)
          title && !hasIconAtLeft && (
            <h3
              class={
                contentLayout === 'centered'
                  ? 'mb-1 text-xl font-black tracking-tight leading-tight'
                  : 'mb-1 text-xl font-black tracking-tight leading-tight'
              }
            >
              {title}
            </h3>
          )
        }

        {(date || dateRange) && (
          <p class="mb-2 text-xs font-bold tracking-wide text-gray-600 uppercase">
            {date && <DateDisplay date={date} />}
            {dateRange && (
              <>
                <DateDisplay date={dateRange.start} /> -{' '}
                <DateDisplay date={dateRange.end} />
              </>
            )}
          </p>
        )}

        {description && (
          <p class="text-sm leading-relaxed text-gray-700 break-words">
            {description}
          </p>
        )}

        <slot />
      </>
    )
  }
</Tag>
