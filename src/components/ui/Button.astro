---
interface Props {
  text: string;
  href?: string;
  target?: '_self' | '_blank';
  variant?: 'primary' | 'secondary' | 'outline' | 'warning';
  size?: 'sm' | 'md' | 'lg';
  block?: boolean;
  ariaLabel?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  download?: boolean | string;
  loading?: boolean;
  class?: string;
}

const {
  text, href, target = '_self', variant = 'primary', size = 'md', block = false,
  ariaLabel = text, download = false, type, disabled = false, loading = false,
  class: extraClass = '',
} = Astro.props;

const variants = {
  primary: 'bg-secondary text-white border-black/[0.04] hover:bg-secondary-hover active:scale-[0.98]',
  secondary: 'bg-secondary/10 text-secondary border-secondary/20 hover:bg-secondary/20 active:scale-[0.98]',
  outline: 'bg-white border-gray-200 text-slate-900 hover:border-secondary hover:bg-secondary/5 active:scale-[0.98]',
  warning: 'bg-slate-900 text-white border-transparent hover:bg-slate-800 active:scale-[0.98]',
};

const sizes = {
  sm: 'px-5 py-2.5 text-xs rounded-full',
  md: 'px-6 py-3.5 text-sm rounded-full',
  lg: 'px-8 py-4.5 text-base rounded-full',
};

const width = block ? 'w-full' : '';
const disabledClasses = disabled ? 'opacity-50 cursor-not-allowed pointer-events-none' : '';

const Element = href ? 'a' : 'button';
const displayText = loading ? '...' : text;
---

<Element
  href={href}
  target={href ? target : undefined}
  download={href ? download || undefined : undefined}
  aria-label={ariaLabel}
  rel={href && target === '_blank' ? 'noopener noreferrer' : undefined}
  type={!href ? type || 'button' : undefined}
  disabled={!href ? disabled || loading : undefined}
  class:list={[
    'group inline-flex items-center justify-center font-bold transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] border select-none tracking-wide font-sans',
    variants[variant], sizes[size], width, extraClass, disabledClasses,
  ]}
>
  <span class="flex items-center gap-3">
    <slot name="icon-left" />
    <span>{displayText}</span>

    <!-- Inner kinetic trailing container -->
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-black/[0.03] group-hover:bg-black/[0.08] transition-colors duration-300 ml-1 shrink-0">
      <slot name="icon-right">
        <svg class="w-3 h-3 transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="7" y1="17" x2="17" y2="7"></line>
          <polyline points="7 7 17 7 17 17"></polyline>
        </svg>
      </slot>
    </span>
  </span>
</Element>
