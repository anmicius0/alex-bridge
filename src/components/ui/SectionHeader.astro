---
// src/components/SectionHeader.astro
interface Props {
  title: string;
  description: string;
  class?: string;
}
const { title, description, class: extraClass = '' } = Astro.props;
---

<div class={`mb-8 text-center max-w-3xl mx-auto ${extraClass}`}>
  <h2 class="mb-3 text-2xl md:text-3xl font-black uppercase tracking-tight">
    {title}
  </h2>
  <div
    class="w-10 h-1.5 bg-[var(--color-accent)] border-[2px] border-black rounded-full mx-auto mb-3"
  >
  </div>
  <p class="text-base text-gray-600 font-medium">{description}</p>
</div>
